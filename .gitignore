# Ignore everything by default
*

# Allow directories so git can recurse into them
!*/

# Allow TeX and PDF files anywhere in the tree
!**/*.tex
!**/*.pdf
!**/*.m
!**/*.py
!**/*.md
!**/*.yaml
!**/.gitkeep

# Keep this file tracked
!.gitignore

# Ignore hidden directories
.agent/**
.claude/**
.vscode/**
.tmp/**

# Ignore LaTeX build artifacts
**/*.fls
**/*.aux
**/*.log
**/*.gz
**/*.out
**/*.toc
**/*.fdb_latexmk
**/*.synctex.gz
**/*.auxlock